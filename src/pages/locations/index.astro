---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { config } from '../../config';

const { business, contact, cta } = config;

function slugify(str: string): string {
  return str.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}
---

<BaseLayout
  title="Service Areas"
  description={`${business.name} proudly serves ${config.serviceAreas.primary.join(', ')} and surrounding ${contact.address.state} communities.`}
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Locations', url: '/locations' }]}
>
  <!-- HERO -->
  <section class="relative py-20 lg:py-28 overflow-hidden" style="background: var(--color-secondary);">
    <div class="hero-pattern"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,30,66,0.97) 0%, rgba(15,30,66,0.85) 100%);"></div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label mb-4 justify-center" style="color: var(--color-accent-warm);">Service Areas</p>
      <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark);">
        Areas We Serve
      </h1>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--color-text-on-dark-muted);">
        {business.name} proudly serves {contact.address.city} and the surrounding {contact.address.state} communities with professional tax and accounting services.
      </p>
    </div>
  </section>

  <!-- PRIMARY AREAS -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <p class="section-label mb-4">Primary Service Areas</p>
      <h2 class="text-3xl font-bold mb-8" style="font-family: var(--font-family-display);">
        Our Home Turf
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {config.serviceAreas.primary.map((area) => (
          <a
            href={`/locations/${slugify(area)}`}
            class="group p-6 rounded-xl transition-all duration-200 hover:shadow-lg"
            style="background: var(--color-surface); box-shadow: var(--shadow-card); border: 1px solid var(--color-border);"
          >
            <div class="flex items-center gap-3 mb-2">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--color-primary-light); color: var(--color-primary);">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <h3 class="text-lg font-bold group-hover:text-[var(--color-primary)] transition-colors">
                {area}, {contact.address.state}
              </h3>
            </div>
            <p class="text-sm ml-11" style="color: var(--color-text-muted);">
              Priority scheduling &middot; Fast response
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SECONDARY AREAS -->
  {config.serviceAreas.secondary.length > 0 && (
    <section class="py-16 lg:py-24" style="background: var(--color-bg-alt);">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <p class="section-label mb-4">Extended Service Areas</p>
        <h2 class="text-3xl font-bold mb-8" style="font-family: var(--font-family-display);">
          We Also Serve
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {config.serviceAreas.secondary.map((area) => (
            <a
              href={`/locations/${slugify(area)}`}
              class="group p-6 rounded-xl transition-all duration-200 hover:shadow-lg"
              style="background: var(--color-surface); box-shadow: var(--shadow-card); border: 1px solid var(--color-border);"
            >
              <div class="flex items-center gap-3 mb-2">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--color-bg-alt); color: var(--color-text-muted);">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                </div>
                <h3 class="text-lg font-bold group-hover:text-[var(--color-primary)] transition-colors">
                  {area}, {contact.address.state}
                </h3>
              </div>
              <p class="text-sm ml-11" style="color: var(--color-text-muted);">
                Full service available
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-16 lg:py-20 text-center teal-gradient relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M20 20.5V18H0v-2h20v-2l2 2.5-2 2.5z&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="font-family: var(--font-family-display); color: white;">
        Don't See Your Area?
      </h2>
      <p class="text-lg mb-8" style="color: rgba(255,255,255,0.8);">
        Give us a call — we may still be able to help. We're always expanding our coverage.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={cta.primary.href} class="btn-primary !bg-white !shadow-xl" style="color: var(--color-primary-dark) !important; background: white !important;">
          {cta.primary.label}
        </a>
        <a href={`tel:${contact.phoneRaw}`} class="btn-ghost !border-white/30 hover:!bg-white/10">{cta.phone.label}</a>
      </div>
    </div>
  </section>
</BaseLayout>

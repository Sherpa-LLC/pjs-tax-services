---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';
import { getEntry, render } from 'astro:content';

const { business, contact, cta } = config;
const allAreas = [...config.serviceAreas.primary, ...config.serviceAreas.secondary];

const about = await getEntry('pages', 'about');
const { heroImage, heroAlt, metaDescription } = about.data;
const { Content } = await render(about);

const metrics = [
  { value: '25+', label: 'Years of Professional Experience' },
  { value: '20%', label: 'Year-Over-Year Client Growth' },
  { value: '97%', label: 'Client Retention Rate' },
  { value: '90%', label: 'Referral Rate' },
];
---

<BaseLayout
  title="About Us"
  description={metaDescription}
  schemaType="about"
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'About', url: '/about' }]}
>
  <!-- HERO -->
  <section class="relative py-24 lg:py-32 overflow-hidden" style="background: var(--color-secondary);">
    <div class="hero-pattern"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,30,66,0.97) 0%, rgba(15,30,66,0.85) 100%);"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="section-label mb-4" style="color: var(--color-accent-warm);">About Us</p>
          <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark);">
            {about.data.title || `About ${business.name}`}
          </h1>
          <p class="text-lg leading-relaxed" style="color: var(--color-text-on-dark-muted);">
            Trusted by individuals and businesses across Clinton County. Over 25 years of professional experience dedicated to your financial success.
          </p>
        </div>
        {heroImage && (
          <div class="relative">
            <div class="absolute -inset-4 rounded-2xl opacity-15" style="background: var(--color-primary); filter: blur(40px);"></div>
            <img
              src={heroImage}
              alt={heroAlt || 'About us'}
              class="relative w-full rounded-xl object-cover shadow-2xl"
              style="aspect-ratio: 16/10; border: 1px solid rgba(255,255,255,0.08);"
              width="640"
              height="400"
              fetchpriority="high"
            />
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- METRICS BAR -->
  <section class="py-0" style="background: var(--color-primary);">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-white/15">
        {metrics.map((m) => (
          <div class="text-center py-8 lg:py-10 px-4">
            <p class="text-3xl lg:text-4xl font-bold text-white mb-1">{m.value}</p>
            <p class="text-xs sm:text-sm font-medium text-white/70">{m.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PAMELA STRONG PROFILE -->
  <section class="py-20 lg:py-28" style="background: var(--color-bg);">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <!-- Profile Card -->
        <div class="lg:col-span-2">
          <div class="sticky top-32 rounded-xl overflow-hidden" style="background: var(--color-surface); box-shadow: var(--shadow-card); border: 1px solid var(--color-border);">
            <div class="p-6 lg:p-8">
              <div class="w-20 h-20 rounded-xl flex items-center justify-center text-2xl font-bold text-white mb-5" style="background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));">
                PS
              </div>
              <h3 class="text-xl font-bold mb-1" style="font-family: var(--font-family-display);">Pamela Strong</h3>
              <p class="text-sm font-medium mb-4" style="color: var(--color-primary);">CEO & Founder</p>
              <p class="text-sm leading-relaxed mb-6" style="color: var(--color-text-muted);">
                Founded PJS Tax Accounting Service with a passion for helping people navigate the complexities of the tax system.
              </p>
              <div class="space-y-3 text-sm">
                <div class="flex items-center gap-3" style="color: var(--color-text-light);">
                  <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342" />
                  </svg>
                  Tax Preparation Expert
                </div>
                <div class="flex items-center gap-3" style="color: var(--color-text-light);">
                  <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                  </svg>
                  IRS Registered Preparer
                </div>
                <div class="flex items-center gap-3" style="color: var(--color-text-light);">
                  <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                  Wilmington, Ohio
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-3">
          <div class="prose prose-lg max-w-none" style="--tw-prose-headings: var(--color-text); --tw-prose-body: var(--color-text-light); --tw-prose-links: var(--color-primary);">
            <Content />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE AREAS -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg-alt);">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label mb-4 justify-center">Coverage Area</p>
      <h2 class="text-3xl font-bold mb-8" style="font-family: var(--font-family-display);">
        Proudly Serving {config.contact.address.city} & Beyond
      </h2>
      <div class="flex flex-wrap justify-center gap-3">
        {allAreas.map((area) => (
          <span class="px-4 py-2 rounded-full text-sm font-medium" style="background: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text-light);">
            {area}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-20 text-center teal-gradient relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M20 20.5V18H0v-2h20v-2l2 2.5-2 2.5z&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="font-family: var(--font-family-display); color: white;">
        Ready to Work with Us?
      </h2>
      <p class="text-lg mb-8" style="color: rgba(255,255,255,0.8);">
        Get in touch today for a free consultation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={cta.primary.href} class="btn-primary !bg-white !shadow-xl" style="color: var(--color-primary-dark) !important; background: white !important;">
          {cta.primary.label}
        </a>
        <a href={`tel:${contact.phoneRaw}`} class="btn-ghost !border-white/30 hover:!bg-white/10">{cta.phone.label}</a>
      </div>
    </div>
  </section>
</BaseLayout>

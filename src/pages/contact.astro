---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';

const { business, contact, hours } = config;
const currentYear = new Date().getFullYear();
const taxYears = [currentYear, currentYear - 1, currentYear - 2, currentYear - 3];
---

<BaseLayout
  title="Contact Us"
  description={`Get in touch with ${business.name}. Call ${contact.phone} or fill out our contact form for a free consultation.`}
  schemaType="contact"
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Contact', url: '/contact' }]}
>
  <!-- HERO -->
  <section class="relative py-20 lg:py-28 overflow-hidden" style="background: var(--color-secondary);">
    <div class="hero-pattern"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,30,66,0.97) 0%, rgba(15,30,66,0.85) 100%);"></div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label mb-4 justify-center" style="color: var(--color-accent-warm);">Get In Touch</p>
      <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark);">
        Book Your Free Consultation
      </h1>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--color-text-on-dark-muted);">
        Ready to take the stress out of tax season? Reach out today and let's discuss how we can help.
      </p>
    </div>
  </section>

  <!-- CONTACT GRID -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- FORM -->
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold mb-2" style="font-family: var(--font-family-display);">Schedule a Consultation</h2>
          <p class="text-sm mb-8" style="color: var(--color-text-muted);">Fill out the form below and we'll get back to you within one business day.</p>
          <form class="space-y-6" action="/contact" method="POST">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-semibold mb-2" style="color: var(--color-text-light);">Full Name *</label>
                <input type="text" id="name" name="name" required placeholder="John Smith"
                  class="w-full px-4 py-3 rounded-lg text-sm transition-all"
                  style="border: 1.5px solid var(--color-border); background: var(--color-surface);"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-semibold mb-2" style="color: var(--color-text-light);">Phone</label>
                <input type="tel" id="phone" name="phone" placeholder="(555) 123-4567"
                  class="w-full px-4 py-3 rounded-lg text-sm transition-all"
                  style="border: 1.5px solid var(--color-border); background: var(--color-surface);"
                />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold mb-2" style="color: var(--color-text-light);">Email Address *</label>
              <input type="email" id="email" name="email" required placeholder="john@example.com"
                class="w-full px-4 py-3 rounded-lg text-sm transition-all"
                style="border: 1.5px solid var(--color-border); background: var(--color-surface);"
              />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="service" class="block text-sm font-semibold mb-2" style="color: var(--color-text-light);">Service Needed</label>
                <select id="service" name="service"
                  class="w-full px-4 py-3 rounded-lg text-sm transition-all appearance-none"
                  style="border: 1.5px solid var(--color-border); background: var(--color-surface); background-image: url('data:image/svg+xml;charset=utf-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 20 20%22 fill=%22%236B7D93%22%3E%3Cpath fill-rule=%22evenodd%22 d=%22M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z%22 clip-rule=%22evenodd%22/%3E%3C/svg%3E'); background-position: right 12px center; background-repeat: no-repeat; background-size: 18px; padding-right: 40px;"
                >
                  <option value="">Select a service...</option>
                  {config.services.map((svc) => (
                    <option value={svc.slug}>{svc.name}</option>
                  ))}
                  <option value="other">Other / Not Sure</option>
                </select>
              </div>
              <div>
                <label for="tax-year" class="block text-sm font-semibold mb-2" style="color: var(--color-text-light);">Tax Year</label>
                <select id="tax-year" name="tax-year"
                  class="w-full px-4 py-3 rounded-lg text-sm transition-all appearance-none"
                  style="border: 1.5px solid var(--color-border); background: var(--color-surface); background-image: url('data:image/svg+xml;charset=utf-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 20 20%22 fill=%22%236B7D93%22%3E%3Cpath fill-rule=%22evenodd%22 d=%22M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z%22 clip-rule=%22evenodd%22/%3E%3C/svg%3E'); background-position: right 12px center; background-repeat: no-repeat; background-size: 18px; padding-right: 40px;"
                >
                  <option value="">Select tax year...</option>
                  {taxYears.map((yr) => (
                    <option value={String(yr)}>{yr}</option>
                  ))}
                  <option value="multiple">Multiple Years</option>
                </select>
              </div>
            </div>
            <div>
              <label for="message" class="block text-sm font-semibold mb-2" style="color: var(--color-text-light);">How can we help? *</label>
              <textarea id="message" name="message" rows={5} required placeholder="Tell us about your tax situation or what you need help with..."
                class="w-full px-4 py-3 rounded-lg text-sm transition-all resize-none"
                style="border: 1.5px solid var(--color-border); background: var(--color-surface);"
              ></textarea>
            </div>

            <!-- Turnstile placeholder -->
            <div class="cf-turnstile" data-sitekey="0x4AAAAAAAe0EJ2NwHkMsJro" data-theme="light"></div>

            <button type="submit" class="btn-primary w-full sm:w-auto">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
              </svg>
              Send Message
            </button>
          </form>
        </div>

        <!-- INFO SIDEBAR -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Quick Contact -->
          <div class="p-6 rounded-xl" style="background: var(--color-surface); box-shadow: var(--shadow-card); border: 1px solid var(--color-border);">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: var(--color-primary-light); color: var(--color-primary);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
              </div>
              <h3 class="font-bold text-lg">Call Us</h3>
            </div>
            <a href={`tel:${contact.phoneRaw}`} class="text-xl font-bold block mb-1 hover:underline" style="color: var(--color-primary);">
              {contact.phone}
            </a>
            <p class="text-xs" style="color: var(--color-text-muted);">Monday - Friday during business hours</p>
          </div>

          <!-- Email -->
          <div class="p-6 rounded-xl" style="background: var(--color-surface); box-shadow: var(--shadow-card); border: 1px solid var(--color-border);">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: var(--color-primary-light); color: var(--color-primary);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <h3 class="font-bold text-lg">Email</h3>
            </div>
            <a href={`mailto:${contact.email}`} class="text-sm font-medium hover:underline transition-colors" style="color: var(--color-primary);">
              {contact.email}
            </a>
          </div>

          <!-- Location -->
          <div class="p-6 rounded-xl" style="background: var(--color-surface); box-shadow: var(--shadow-card); border: 1px solid var(--color-border);">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: var(--color-primary-light); color: var(--color-primary);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <h3 class="font-bold text-lg">Visit Us</h3>
            </div>
            <address class="not-italic text-sm leading-relaxed" style="color: var(--color-text-light);">
              {contact.address.street}<br />
              {contact.address.city}, {contact.address.state} {contact.address.zip}
            </address>
          </div>

          <!-- Hours -->
          <div class="p-6 rounded-xl" style="background: var(--color-surface); box-shadow: var(--shadow-card); border: 1px solid var(--color-border);">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background: var(--color-primary-light); color: var(--color-primary);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="font-bold text-lg">Office Hours</h3>
            </div>
            <dl class="space-y-1.5 text-sm">
              {Object.entries(hours).map(([day, h]) => (
                <div class="flex justify-between gap-4">
                  <dt class="capitalize" style="color: var(--color-text-muted);">{day}</dt>
                  <dd class="font-medium" style={h === 'Closed' ? 'color: var(--color-text-muted); opacity: 0.6;' : ''}>{h}</dd>
                </div>
              ))}
            </dl>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

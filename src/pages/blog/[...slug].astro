---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { config } from '../../config';
import { getCollection, render } from 'astro:content';

const { contact, cta } = config;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, date, author, metaDescription, heroImage, heroAlt, category, readingTime } = post.data;
const { Content } = await render(post);

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={title}
  description={metaDescription}
  image={heroImage}
  schemaType="blog-post"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Blog', url: '/blog' },
    { name: title, url: `/blog/${post.id}` },
  ]}
  blogPost={{ title, description: metaDescription, date, author, image: heroImage }}
>
  <!-- HERO -->
  {heroImage && (
    <section class="relative py-32 lg:py-40 overflow-hidden">
      <div class="absolute inset-0">
        <img
          src={heroImage}
          alt={heroAlt || title}
          class="w-full h-full object-cover"
          width="1920"
          height="1080"
          fetchpriority="high"
          decoding="async"
        />
        <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(11,21,38,0.88), rgba(11,21,38,0.78), rgba(11,21,38,0.92));"></div>
      </div>
      <div class="hero-pattern"></div>
      <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <nav class="mb-6 text-sm flex items-center gap-2" style="color: var(--color-text-on-dark-muted);">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
          <a href="/blog" class="hover:text-white transition-colors">Blog</a>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
          <span class="truncate" style="color: var(--color-text-on-dark);">{title}</span>
        </nav>
        {category && (
          <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full text-white mb-4" style="background: rgba(12,140,150,0.8); backdrop-filter: blur(8px);">
            {category}
          </span>
        )}
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark); line-height: 1.1;">
          {title}
        </h1>
        <div class="flex flex-wrap items-center gap-4 text-sm" style="color: var(--color-text-on-dark-muted);">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
            {formattedDate}
          </span>
          {readingTime && (
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              {readingTime}
            </span>
          )}
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
            By {author}
          </span>
        </div>
      </div>
    </section>
  )}

  <!-- ARTICLE -->
  <article class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none" style="--tw-prose-headings: var(--color-text); --tw-prose-body: var(--color-text-light); --tw-prose-links: var(--color-primary); --tw-prose-bold: var(--color-text);">
        <Content />
      </div>
    </div>
  </article>

  <!-- CTA -->
  <section class="py-16 lg:py-20 text-center teal-gradient relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M20 20.5V18H0v-2h20v-2l2 2.5-2 2.5z&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4" style="font-family: var(--font-family-display); color: white;">
        Ready to Get Started?
      </h2>
      <p class="text-lg mb-8" style="color: rgba(255,255,255,0.8);">
        Contact us today for a free consultation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={cta.primary.href} class="btn-primary !bg-white !shadow-xl" style="color: var(--color-primary-dark) !important; background: white !important;">
          {cta.primary.label}
        </a>
        <a href="/blog" class="btn-ghost !border-white/30 hover:!bg-white/10">&larr; Back to Blog</a>
      </div>
    </div>
  </section>
</BaseLayout>

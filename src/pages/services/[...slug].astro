---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { config } from '../../config';
import { getCollection, render } from 'astro:content';

const { contact, cta } = config;

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((svc) => ({
    params: { slug: svc.data.slug },
    props: { service: svc },
  }));
}

const { service } = Astro.props;
const { title, metaTitle, metaDescription, heroImage, heroAlt, shortDescription, faqs } = service.data;
const { Content } = await render(service);
---

<BaseLayout
  title={metaTitle || title}
  description={metaDescription}
  schemaType="service"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/services' },
    { name: title, url: `/services/${service.data.slug}` },
  ]}
  serviceData={{ name: title, description: shortDescription, image: heroImage }}
  faqs={faqs}
>
  <!-- HERO -->
  <section class="relative py-28 lg:py-36 overflow-hidden" style="background: var(--color-secondary);">
    {heroImage && (
      <div class="absolute inset-0">
        <img src={heroImage} alt={heroAlt} class="w-full h-full object-cover" width="1920" height="1080" fetchpriority="high" />
        <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,30,66,0.92) 0%, rgba(15,30,66,0.78) 100%);"></div>
      </div>
    )}
    <div class="hero-pattern"></div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm flex items-center gap-2" style="color: var(--color-text-on-dark-muted);">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
        <a href="/services" class="hover:text-white transition-colors">Services</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
        <span style="color: var(--color-text-on-dark);">{title}</span>
      </nav>
      <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="font-family: var(--font-family-display); color: var(--color-text-on-dark);">
        {title}
      </h1>
      <p class="text-lg max-w-2xl leading-relaxed" style="color: var(--color-text-on-dark-muted);">
        {shortDescription}
      </p>
      <div class="mt-8">
        <a href={cta.primary.href} class="btn-primary">{cta.primary.label}</a>
      </div>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="py-16 lg:py-24" style="background: var(--color-bg);">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none" style="--tw-prose-headings: var(--color-text); --tw-prose-body: var(--color-text-light); --tw-prose-links: var(--color-primary);">
        <Content />
      </div>
    </div>
  </section>

  <!-- FAQS -->
  {faqs && faqs.length > 0 && (
    <section class="py-16 lg:py-24" style="background: var(--color-bg-alt);">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <p class="section-label mb-4">Frequently Asked Questions</p>
        <h2 class="text-3xl font-bold mb-10" style="font-family: var(--font-family-display);">
          Common Questions About {title}
        </h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <details class="accordion-panel">
              <summary>
                <span class="flex-1">{faq.question}</span>
                <svg class="w-5 h-5 flex-shrink-0 transition-transform duration-300" style="color: var(--color-primary);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
              </summary>
              <div class="panel-content">
                <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-16 lg:py-20 text-center teal-gradient relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M20 20.5V18H0v-2h20v-2l2 2.5-2 2.5z&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="relative z-10 mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="font-family: var(--font-family-display); color: white;">
        Ready to Get Started?
      </h2>
      <p class="text-lg mb-8" style="color: rgba(255,255,255,0.8);">
        Contact us today for a free consultation about {title.toLowerCase()}.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={cta.primary.href} class="btn-primary !bg-white !shadow-xl" style="color: var(--color-primary-dark) !important; background: white !important;">
          {cta.primary.label}
        </a>
        <a href={`tel:${contact.phoneRaw}`} class="btn-ghost !border-white/30 hover:!bg-white/10">{cta.phone.label}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.accordion-panel').forEach((panel) => {
    panel.addEventListener('toggle', (e) => {
      const icon = (e.target as HTMLElement).querySelector('summary svg:last-child');
      if (icon) {
        icon.style.transform = (e.target as HTMLDetailsElement).open ? 'rotate(45deg)' : '';
      }
    });
  });
</script>
